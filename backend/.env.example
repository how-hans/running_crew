DATABASE_URL=postgresql://user:password@host/dbname

# Vertex AI endpoint (defaults already point at the trained model; override if needed)
VERTEX_PROJECT=804581610406
VERTEX_LOCATION=us-central1
VERTEX_ENDPOINT_ID=3043580676835115008

# Auth: locally, `gcloud auth application-default login` is usually enough and
# neither of these is needed. On Render, paste a service account key's JSON
# content into GOOGLE_APPLICATION_CREDENTIALS_JSON instead.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
